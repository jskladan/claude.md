{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ {file} == *.py ]]; then black {file}; fi"
          },
          {
            "type": "command",
            "command": "if [[ {file} == *.py ]]; then isort {file}; fi"
          }
        ]
      }
    ]
  },
  "tools": {
    "preferences": {
      "bash": {
        "timeout": 300000
      },
      "grep": {
        "defaultMode": "content"
      }
    }
  }
}
